<Window x:Class="Marketplace_System.Views.UserAccountFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Account"
        Height="520"
        Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="FormTitleText" FontSize="22" FontWeight="SemiBold" Foreground="#0F172A"/>

        <Border Grid.Row="1" Margin="0,16,0,16" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="White" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Full Name" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox x:Name="FullNameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Padding="8,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Email" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox x:Name="EmailTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Padding="8,6"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Mobile" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox x:Name="MobileTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Padding="8,6"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="City" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox x:Name="CityTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" Padding="8,6"/>

                <TextBlock x:Name="PasswordLabelText" Grid.Row="6" Grid.Column="0" Text="Password" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <PasswordBox x:Name="PasswordBox" Grid.Row="6" Grid.Column="1" Padding="8,6"/>

                <TextBlock x:Name="HelperText" Grid.Row="7" Grid.ColumnSpan="2" Margin="0,10,0,0" Foreground="#64748B" TextWrapping="Wrap" FontSize="12"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Height="34" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="Save" Width="90" Height="34" Background="#2563EB" Foreground="White" BorderBrush="#1D4ED8" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>