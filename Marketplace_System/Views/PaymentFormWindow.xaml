<Window x:Class="Marketplace_System.Views.PaymentFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment"
        Height="560"
        Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="FormTitleText" FontSize="22" FontWeight="SemiBold" Foreground="#0F172A"/>
        <Border Grid.Row="1" Margin="0,16,0,16" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Background="White" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Reference #" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox x:Name="ReferenceTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Padding="8,6"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Order #" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox x:Name="OrderTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Padding="8,6"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Payer" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox x:Name="PayerTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Padding="8,6"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Recipient" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <TextBox x:Name="RecipientTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" Padding="8,6"/>
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Method" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <ComboBox x:Name="MethodComboBox" Grid.Row="4" Grid.Column="1" Margin="0,0,0,10" Padding="8,6">
                    <ComboBoxItem Content="Cash"/>
                    <ComboBoxItem Content="Bank Transfer"/>
                    <ComboBoxItem Content="GCash"/>
                    <ComboBoxItem Content="Card"/>
                </ComboBox>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Status" VerticalAlignment="Center" Margin="0,0,10,10"/>
                <ComboBox x:Name="StatusComboBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,10" Padding="8,6">
                    <ComboBoxItem Content="Pending"/>
                    <ComboBoxItem Content="Paid"/>
                    <ComboBoxItem Content="Failed"/>
                    <ComboBoxItem Content="Refunded"/>
                </ComboBox>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Amount" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="AmountTextBox" Grid.Row="6" Grid.Column="1" Padding="8,6"/>
            </Grid>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="90" Height="34" Margin="0,0,8,0" Click="CancelButton_Click"/>
            <Button Content="Save" Width="90" Height="34" Background="#2563EB" Foreground="White" BorderBrush="#1D4ED8" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>