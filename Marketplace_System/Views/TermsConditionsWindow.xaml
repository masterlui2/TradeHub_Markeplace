<Window x:Class="Marketplace_System.Views.TermsConditionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buyer Terms &amp; Conditions"
        Width="560"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Buyer Terms &amp; Conditions"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#1A3B2E"/>

        <Border Grid.Row="1"
                Margin="0,14,0,14"
                Padding="14"
                CornerRadius="10"
                BorderBrush="#DCEBE4"
                BorderThickness="1"
                Background="White">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Please read these terms carefully before placing your order."
                               TextWrapping="Wrap"
                               Foreground="#4B5F59"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="1. Order Accuracy"
                               FontWeight="SemiBold"
                               Foreground="#1A3B2E"/>
                    <TextBlock Text="You are responsible for reviewing product details, quantities, and prices before checkout."
                               TextWrapping="Wrap"
                               Foreground="#4B5F59"
                               Margin="0,4,0,12"/>

                    <TextBlock Text="2. Fulfillment and Delivery"
                               FontWeight="SemiBold"
                               Foreground="#1A3B2E"/>
                    <TextBlock Text="Choose your fulfillment option (pickup or delivery) correctly. Inaccurate address details may cause delays."
                               TextWrapping="Wrap"
                               Foreground="#4B5F59"
                               Margin="0,4,0,12"/>

                    <TextBlock Text="3. Payments"
                               FontWeight="SemiBold"
                               Foreground="#1A3B2E"/>
                    <TextBlock Text="Payments must be completed within the required period. Orders may be cancelled when payment is not settled on time."
                               TextWrapping="Wrap"
                               Foreground="#4B5F59"
                               Margin="0,4,0,12"/>

                    <TextBlock Text="4. Communication"
                               FontWeight="SemiBold"
                               Foreground="#1A3B2E"/>
                    <TextBlock Text="Users must communicate respectfully with sellers and platform support. Harassment and abusive behavior are prohibited."
                               TextWrapping="Wrap"
                               Foreground="#4B5F59"
                               Margin="0,4,0,12"/>

                    <TextBlock Text="5. Cancellations, Refunds, and Disputes"
                               FontWeight="SemiBold"
                               Foreground="#1A3B2E"/>
                    <TextBlock Text="Requests are reviewed based on marketplace policy and available order evidence. Decisions are final once resolved by the platform."
                               TextWrapping="Wrap"
                               Foreground="#4B5F59"
                               Margin="0,4,0,12"/>

                    <TextBlock Text="6. Policy Updates"
                               FontWeight="SemiBold"
                               Foreground="#1A3B2E"/>
                    <TextBlock Text="FarmHub may revise these terms from time to time. Continued use of the platform means acceptance of updated policies."
                               TextWrapping="Wrap"
                               Foreground="#4B5F59"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2"
                Content="Close"
                Width="100"
                Height="34"
                HorizontalAlignment="Right"
                Background="#2D6A4F"
                Foreground="White"
                BorderThickness="0"
                Click="CloseButton_Click"/>
    </Grid>
</Window>