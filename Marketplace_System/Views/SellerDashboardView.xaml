<UserControl x:Class="Marketplace_System.Views.SellerDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <!-- ONE ROOT ELEMENT ONLY -->
    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel Margin="0,0,10,0">

                <!-- MAIN CARD -->
                <Border Background="White"
                        CornerRadius="18"
                        Padding="20"
                        BorderBrush="#DCEAE3"
                        BorderThickness="1"
                        Margin="0,0,0,20">

                    <StackPanel>

                        <!-- HEADER -->
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="Your Listings"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="#1F4E3D"
                                       DockPanel.Dock="Left" Width="152"/>

                            <Button Content="Create Listing"
                                    Click="CreateListingButton_Click"
                                    Padding="10,6"
                                    Background="#2E7D5B"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    HorizontalAlignment="Right"/>
                        </DockPanel>

                        <!-- EMPTY MESSAGE -->
                        <TextBlock x:Name="EmptyListingsTextBlock"
                                   Text="You have no listings yet."
                                   Foreground="#6B7280"
                                   FontStyle="Italic"
                                   Margin="0,0,0,10"
                                   Visibility="Collapsed"/>

                        <!-- LISTINGS -->
                        <ItemsControl x:Name="ListingsControl">

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <Border Background="#F9FDFA"
                                            CornerRadius="14"
                                            Padding="14"
                                            BorderBrush="#E0EFE7"
                                            BorderThickness="1"
                                            Margin="0,0,0,10">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- LEFT CONTENT -->
                                            <StackPanel>
                                                <TextBlock Text="{Binding ProductName}"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"/>

                                                <TextBlock Text="{Binding MetaText}"
                                                           Margin="0,4,0,0"
                                                           Foreground="#4B5563"/>

                                                <TextBlock Text="{Binding PickupAddress}"
                                                           Margin="0,4,0,0"
                                                           Foreground="#6B7280"
                                                           FontSize="12"/>
                                            </StackPanel>

                                            <!-- ACTION BUTTONS -->
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">

                                                <Button Content="View"
                                                        Click="ViewListing_Click"
                                                        Tag="{Binding ListingId}"
                                                        Margin="0,0,6,0"
                                                        Padding="10,4"
                                                        Background="#E6F4EC"
                                                        BorderThickness="0"/>

                                                <Button Content="Edit"
                                                        Click="EditListing_Click"
                                                        Tag="{Binding ListingId}"
                                                        Margin="0,0,6,0"
                                                        Padding="10,4"
                                                        Background="#D8EAFE"
                                                        BorderThickness="0"/>

                                                <Button Content="Delete"
                                                        Click="DeleteListing_Click"
                                                        Tag="{Binding ListingId}"
                                                        Padding="10,4"
                                                        Background="#FEE2E2"
                                                        BorderThickness="0"/>
                                            </StackPanel>

                                        </Grid>
                                    </Border>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</UserControl>