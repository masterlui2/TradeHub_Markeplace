<UserControl x:Class="Marketplace_System.Views.SellerDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,10,0">

                <Border Background="White"
                        CornerRadius="18"
                        Padding="20"
                        BorderBrush="#DCEAE3"
                        BorderThickness="1"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Seller Dashboard"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#1F4E3D"/>

                        <TextBlock x:Name="SellerInfoTextBlock"
                                   Margin="0,4,0,16"
                                   Foreground="#4B5563"/>

                        <UniformGrid Columns="3" Margin="0,0,0,16">
                            <Border Background="#F3F8F4" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock x:Name="TotalProductsTextBlock" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2E7D5B"/>
                                    <TextBlock Text="Active Products" Foreground="#374151"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F3F8F4" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock x:Name="TotalStockTextBlock" Text="0 kg" FontSize="24" FontWeight="Bold" Foreground="#2E7D5B"/>
                                    <TextBlock Text="Total Stock" Foreground="#374151"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F3F8F4" CornerRadius="12" Padding="14">
                                <StackPanel>
                                    <TextBlock x:Name="AveragePriceTextBlock" Text="₱0.00" FontSize="24" FontWeight="Bold" Foreground="#2E7D5B"/>
                                    <TextBlock Text="Average Price / kg" Foreground="#374151"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="Your Product Cards"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1F4E3D"
                                   Margin="0,0,0,10"/>

                        <TextBlock x:Name="EmptyListingsTextBlock"
                                   Text="You have no listings yet. Add products from the listing form to see them here."
                                   Foreground="#6B7280"
                                   FontStyle="Italic"
                                   Margin="0,0,0,10"
                                   Visibility="Collapsed"/>

                        <ItemsControl x:Name="ListingsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="280"
                                            Margin="0,0,12,12"
                                            Background="#F9FDFA"
                                            CornerRadius="14"
                                            Padding="12"
                                            BorderBrush="#E0EFE7"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <Border Height="130"
                                                    Background="#EAF4EE"
                                                    CornerRadius="10"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                            </Border>

                                            <TextBlock Text="{Binding ProductName}" Margin="0,10,0,2" FontWeight="SemiBold" FontSize="15"/>
                                            <TextBlock Text="{Binding PriceText}" Foreground="#2E7D5B" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding StockText}" Margin="0,4,0,0" Foreground="#4B5563" FontSize="12"/>
                                            <TextBlock Text="{Binding PickupAddress}" Margin="0,4,0,0" Foreground="#6B7280" FontSize="12" TextWrapping="Wrap"/>
                                            <TextBlock Text="View only" Margin="0,8,0,0" Foreground="#6B7280" FontSize="11" FontStyle="Italic"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>