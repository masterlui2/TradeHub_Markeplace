<Window x:Class="Marketplace_System.Views.UserProfileViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Profile"
        Width="460"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="User Profile"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#0F172A"/>

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10"
                Background="White"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Text="User ID" FontWeight="SemiBold" Margin="0,0,10,12"/>
                <TextBlock x:Name="IdText" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="1" Text="Full Name" FontWeight="SemiBold" Margin="0,0,10,12"/>
                <TextBlock x:Name="FullNameText" Grid.Row="1" Grid.Column="1" Margin="0,0,0,12" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="2" Text="Email" FontWeight="SemiBold" Margin="0,0,10,12"/>
                <TextBlock x:Name="EmailText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="3" Text="Mobile" FontWeight="SemiBold" Margin="0,0,10,12"/>
                <TextBlock x:Name="MobileText" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="4" Text="City" FontWeight="SemiBold" Margin="0,0,10,12"/>
                <TextBlock x:Name="CityText" Grid.Row="4" Grid.Column="1" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="5" Text="Created" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <TextBlock x:Name="CreatedAtText" Grid.Row="5" Grid.Column="1"/>
            </Grid>
        </Border>

        <Button Grid.Row="2"
                Content="Close"
                Width="90"
                Height="34"
                HorizontalAlignment="Right"
                Click="CloseButton_Click"/>
    </Grid>
</Window>