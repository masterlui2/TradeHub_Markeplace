<Window x:Class="Marketplace_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Marketplace_System.Views"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        
        Title="FarmHub - Buyer Dashboard"
        Width="1200"
        Height="800"
        Background="#F3F8F4"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
        Background="#A8D5BA"
        Padding="20 15 0 15">
            <!-- Remove right padding to allow profile to be at edge -->
            <Grid VerticalAlignment="Center" Margin="-10,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="168"/>
                    <!-- Logo -->
                    <ColumnDefinition/>
                    <!-- Centered Navigation -->
                    <ColumnDefinition Width="Auto" MinWidth="210"/>
                    <!-- Profile at far right -->
                </Grid.ColumnDefinitions>

                <!-- LOGO -->
                <Button
                        Click="LogoButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" Height="77" Width="168">
                    <Image Source="pack://application:,,,/Images/logo2.png"
       Stretch="Uniform"
       MaxHeight="200" Height="77" Width="167"/>
                </Button>

                <!-- TOP NAVIGATION -->
                <Border Grid.Column="1"
                        Background="#E8F6ED"
                        CornerRadius="13"
                        Padding="12,8"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        BorderBrush="#CDE9DA"
                        BorderThickness="1" Width="286" Height="41" Margin="263,0,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="TopHomeNavButton"
                                Click="TopHomeNavButton_Click"
                                Content="Home"
                                Margin="0,0,8,0"
                                Padding="12,4"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#1F4E3D"
                                FontWeight="SemiBold"/>
                        <Button x:Name="TopOrdersNavButton"
                                Click="TopOrdersNavButton_Click"
                                Content="My Orders"
                                Margin="0,0,8,0"
                                Padding="12,4"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#1F4E3D"
                                FontWeight="SemiBold"/>
                        <Button x:Name="TopCartNavButton"
                                Click="TopCartNavButton_Click"
                                Content="Cart"
                                Margin="0,0,8,0"
                                Padding="12,4"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#1F4E3D"
                                FontWeight="SemiBold"/>
                        <Button x:Name="TopInboxNavButton"
                                Click="TopInboxNavButton_Click"
                                Content="Inbox"
                                Padding="12,4"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#1F4E3D"
                                FontWeight="SemiBold"/>

                    </StackPanel>
                </Border>
                <Border Background="White"
        CornerRadius="15"
        Padding="10,5"
        BorderBrush="#DCEAE3"
        BorderThickness="1" Margin="621,20,192,19" Grid.Column="1" Grid.ColumnSpan="2">

                    <DockPanel>

                        <!-- Search Icon -->
                        <TextBlock Text="🔍"
                   VerticalAlignment="Center"
                   Margin="5,0,8,0"
                   Foreground="#7C8A84"/>
                        <TextBox x:Name="SearchTextBox"
                 Text="Search products"
                 BorderThickness="0"
                 Background="Transparent"
                 Foreground="Gray"
                 VerticalContentAlignment="Center"
                 GotFocus="SearchTextBox_GotFocus"
                 LostFocus="SearchTextBox_LostFocus" DockPanel.Dock="Right" Width="151"/>

                        <!-- TextBox -->

                    </DockPanel>
                </Border>
                <!-- PROFILE DROPDOWN – at very right corner -->
                <Menu Grid.Column="2"
              Background="Transparent"
              VerticalAlignment="Center"
              HorizontalAlignment="Center" Height="38" Width="78">
                    <MenuItem Background="Transparent" BorderThickness="0" Width="78">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="38" Height="38" CornerRadius="19" Background="White">
                                    <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="#2E7D5B" RenderTransformOrigin="-0.119,0.449"/>
                                </Border>
                                <Path Data="M0,0 L6,6 L12,0" Fill="White" VerticalAlignment="Center"
                              Margin="8,0,0,0" Width="12" Height="6" Stretch="Uniform"/>
                            </StackPanel>
                        </MenuItem.Header>
                        <MenuItem.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#1F4E3D"/>
                        </MenuItem.Resources>
                        <MenuItem Header="My Profile"/>
                        <MenuItem Header="Settings"/>
                        <Separator/>
                        <MenuItem Header="Logout" Click="LogoutMenuItem_Click"/>
                    </MenuItem>
                </Menu>
            </Grid>
        </Border>

        <!-- ========== MAIN CONTENT ========== -->
        <Grid Grid.Row="1" Margin="25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Make sure you have the FontAwesome namespace at the top of your XAML file -->
            <ContentControl x:Name="SidebarHost" Grid.Column="0"
                xmlns:fa="http://schemas.fontawesome.io/icons/">
                <ContentControl.Content>
                    <Border Background="White"
                CornerRadius="18"
                Padding="15"
                Margin="0,0,20,0">

                        <StackPanel>
                            <Button x:Name="BrowseProductsNavButton"
                                    Click="BrowseProductsNavButton_Click"
                                    Padding="10"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Stretch"
                                    Cursor="Hand"
                                    Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="ShoppingBasket"
                                                    Width="18"
                                                    Height="12"
                                                    Foreground="#5F6B6A"
                                                    VerticalAlignment="Center"/>
                                    <TextBlock Text="Browse Products"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ================= NAVIGATION SECTION ================= -->

                            <!-- MY ORDERS -->
                            <Button x:Name="MyOrdersNavButton"
        Click="MyOrdersNavButton_Click"
        Padding="10"
        Background="Transparent"
        BorderThickness="0"
        HorizontalContentAlignment="Stretch"
        Cursor="Hand"
        Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Clipboard"
                        Width="17"
                        Height="13"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                        <fa:FontAwesome.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform/>
                                                <SkewTransform/>
                                                <RotateTransform Angle="-0.082"/>
                                                <TranslateTransform/>
                                            </TransformGroup>
                                        </fa:FontAwesome.RenderTransform>
                                    </fa:FontAwesome>
                                    <TextBlock Text="My Orders"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- INBOX -->
                            <Button x:Name="InboxNavButton"
        Click="InboxNavButton_Click"
        Padding="10"
        Background="Transparent"
        BorderThickness="0"
        HorizontalContentAlignment="Stretch"
        Cursor="Hand"
        Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Inbox"
                        Width="18"
                        Height="10"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Inbox"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- CART -->
                            <Button x:Name="MyCartNavButton"
        Click="MyCartNavButton_Click"
        Padding="10"
        Background="Transparent"
        BorderThickness="0"
        HorizontalContentAlignment="Stretch"
        Cursor="Hand"
        Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="ShoppingCart"
                        Width="17"
                        Height="12"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="My Cart"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ================= SELLER TOOLS ================= -->

                            <Separator Margin="0,15"/>

                            <TextBlock Text="Seller Tools"
           FontWeight="Bold"
           Foreground="#1F4E3D"
           Margin="0,0,0,10"/>

                            <!-- CREATE LISTING -->
                            <Button x:Name="CreateListingNavButton"
        Click="CreateListingNavButton_Click"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        Margin="0,0,0,8"
        HorizontalContentAlignment="Stretch"
        Cursor="Hand">
                                <Border Background="#E6F4EC"
            CornerRadius="12"
            Padding="10">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:FontAwesome Icon="PlusCircle"
                            Width="21"
                            Height="12"
                            Foreground="#2E7D5B"
                            VerticalAlignment="Center"/>
                                        <TextBlock Text="Create Listing"
                       FontWeight="SemiBold"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <!-- SELLING -->
                            <Button x:Name="SellingNavButton"
        Click="SellingNavButton_Click"
        Padding="10"
        Background="Transparent"
        BorderThickness="0"
        HorizontalContentAlignment="Stretch"
        Cursor="Hand"
        Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Tags"
                        Width="21"
                        Height="12"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Selling"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ================= CATEGORIES ================= -->

                            <Separator Margin="0,20"/>

                            <TextBlock Text="Categories"
           FontSize="16"
           FontWeight="Bold"
           Margin="0,0,0,12"/>

                            <!-- Vegetables -->
                            <Border Padding="8" CornerRadius="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Leaf"
                        Width="15"
                        Height="10"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Vegetables"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Fruits -->
                            <Border Padding="8" CornerRadius="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Apple"
                        Width="16"
                        Height="12"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Fruits"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Leafy Greens -->
                            <Border Padding="8" CornerRadius="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Leaf"
                        Width="15"
                        Height="12"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Leafy Greens"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Root Crops -->
                            <Border Padding="8" CornerRadius="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Tree"
                        Width="17"
                        Height="13"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Root Crops"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Milk & Eggs -->
                            <Border Padding="8" CornerRadius="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Coffee"
                        Width="15"
                        Height="12"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Milk &amp; Eggs"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Organic Products -->
                            <Border Padding="8" CornerRadius="10">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Leaf"
                        Width="18"
                        Height="18"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Organic Products"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ContentControl.Content>
            </ContentControl>
            <!-- ===== PRODUCT GRID – EXACTLY 3 CARDS PER ROW ===== -->
            <ContentControl x:Name="MainContentHost" Grid.Column="1">
                <ContentControl.Content>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  RenderTransformOrigin="0.59,0.538" Margin="-19,0,0,0">

                        <!-- UniformGrid with Columns="3" forces 3 cards per row -->
                        <UniformGrid Columns="3"
                             Margin="0,0,0,10" Width="930">

                            <!-- Card 1: Asparagus -->

                            <!-- Card 2: Carrots -->
                            <!-- PRODUCT CARD -->
                            <Border
        Margin="32,0,-5,0"
        Background="White"
        CornerRadius="18"
        Padding="12"
        BorderBrush="#DCEAE3"
        BorderThickness="1">

                                <StackPanel>

                                    <!-- PRODUCT IMAGE -->
                                    <Border Height="150"
        Background="#F3F8F4"
        CornerRadius="12"
        ClipToBounds="True">

                                        <Image Source="/Images/carrot.jpg"
           Stretch="UniformToFill"/>
                                    </Border>


                                    <!-- PRODUCT NAME -->
                                    <TextBlock Text="Fresh Carrots"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Margin="0,12,0,2"/>

                                    <!-- PRICE -->
                                    <TextBlock Text="₱210 per kilo"
                   FontSize="13"
                   Foreground="#2E7D5B"
                   FontWeight="Bold"/>

                                    <!-- IMPORTANT INFO -->
                                    <TextBlock Text="Approx. 12 pcs • In Stock"
                   FontSize="11"
                   Foreground="Gray"
                   Margin="0,4,0,8"/>

                                    <Separator Margin="0,6"/>

                                    <!-- SELLER INFO SECTION -->
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">

                                        <!-- PROFILE CIRCLE -->
                                        <Ellipse Width="32"
                     Height="32"
                     Fill="#CFEDE1"/>

                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Juan Dela Cruz"
                           FontSize="12"
                           FontWeight="SemiBold"/>
                                            <TextBlock Text="Davao City"
                           FontSize="11"
                           Foreground="Gray"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- ACTION BUTTON -->
                                    <Button Content="Add to Cart"
                                            
                Click="AddToCartButton_Click"
                Tag="Fresh Carrots|₱210 per kilo|Approx. 12 pcs • In Stock|Juan Dela Cruz"
                Margin="0,10,0,0"
                Background="#2E7D5B"
                Foreground="White"
                BorderThickness="0"
                Padding="6"/>
                                </StackPanel>
                            </Border>

                            <Border
                        Margin="32,0,13,0"
                        Background="White"
                        CornerRadius="18"
                        Padding="12"
                        BorderBrush="#DCEAE3"
                        BorderThickness="1">

                                <StackPanel>

                                    <!-- PRODUCT IMAGE -->
                                    <Border Height="150"
                                Background="#F3F8F4"
                                CornerRadius="12"
                                ClipToBounds="True">

                                        <Image Source="/Images/asp.jpg"
                                    Stretch="UniformToFill"/>
                                    </Border>


                                    <!-- PRODUCT NAME -->
                                    <TextBlock Text="Fresh Asparagus"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Margin="0,12,0,2"/>

                                    <!-- PRICE -->
                                    <TextBlock Text="₱210 per kilo"
                                FontSize="13"
                                Foreground="#2E7D5B"
                                FontWeight="Bold"/>

                                    <!-- IMPORTANT INFO -->
                                    <TextBlock Text="Approx. 12 pcs • In Stock"
                                FontSize="11"
                                Foreground="Gray"
                                Margin="0,4,0,8"/>

                                    <Separator Margin="0,6"/>

                                    <!-- SELLER INFO SECTION -->
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">

                                        <!-- PROFILE CIRCLE -->
                                        <Ellipse Width="32"
                                    Height="32"
                                    Fill="#CFEDE1"/>

                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Juan Dela Cruz"
                                        FontSize="12"
                                        FontWeight="SemiBold"/>
                                            <TextBlock Text="Davao City"
                                        FontSize="11"
                                        Foreground="Gray"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- ACTION BUTTON -->
                                    <Button Content="Add to Cart"
                                               Click="AddToCartButton_Click"
                                Tag="Fresh Asparagus|₱210 per kilo|Approx. 12 pcs • In Stock|Juan Dela Cruz"
                                Margin="0,10,0,0"
                                Background="#2E7D5B"
                                Foreground="White"
                                BorderThickness="0"
                                Padding="6"/>
                                </StackPanel>
                            </Border>
                            <Border
Margin="11,0,37,0"
Background="White"
CornerRadius="18"
Padding="12"
BorderBrush="#DCEAE3"
BorderThickness="1">

                                <StackPanel>

                                    <!-- PRODUCT IMAGE -->
                                    <Border Height="150"
                            Background="#F3F8F4"
                            CornerRadius="12"
                            ClipToBounds="True">

                                        <Image Source="/Images/potato.jpg"
                        Stretch="UniformToFill"/>
                                    </Border>


                                    <!-- PRODUCT NAME -->
                                    <TextBlock Text="Fresh Potatoes"
           FontSize="15"
           FontWeight="SemiBold"
           Margin="0,12,0,2"/>

                                    <!-- PRICE -->
                                    <TextBlock Text="₱210 per kilo"
           FontSize="13"
           Foreground="#2E7D5B"
           FontWeight="Bold"/>

                                    <!-- IMPORTANT INFO -->
                                    <TextBlock Text="Approx. 12 pcs • In Stock"
           FontSize="11"
           Foreground="Gray"
           Margin="0,4,0,8"/>

                                    <Separator Margin="0,6"/>

                                    <!-- SELLER INFO SECTION -->
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">

                                        <!-- PROFILE CIRCLE -->
                                        <Ellipse Width="32"
             Height="32"
             Fill="#CFEDE1"/>

                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Juan Dela Cruz"
                   FontSize="12"
                   FontWeight="SemiBold"/>
                                            <TextBlock Text="Davao City"
                   FontSize="11"
                   Foreground="Gray"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- ACTION BUTTON -->
                                    <Button Content="Add to Cart"
        Margin="0,10,0,0"
        Background="#2E7D5B"
        Foreground="White"
        BorderThickness="0"
        Padding="6"/>
                                </StackPanel>
                            </Border>

                            <!-- Card 3: Beets -->

                            <Border
Margin="32,0,-5,0"
Background="White"
CornerRadius="18"
Padding="12"
BorderBrush="#DCEAE3"
BorderThickness="1" Height="316">

                                <StackPanel>

                                    <!-- PRODUCT IMAGE -->
                                    <Border Height="150"
                            Background="#F3F8F4"
                            CornerRadius="12"
                            ClipToBounds="True">

                                        <Image Source="/Images/beets.jpg"
                            Stretch="UniformToFill"/>
                                    </Border>


                                    <!-- PRODUCT NAME -->
                                    <TextBlock Text="Fresh Beets"
           FontSize="15"
           FontWeight="SemiBold"
           Margin="0,12,0,2"/>

                                    <!-- PRICE -->
                                    <TextBlock Text="₱210 per kilo"
           FontSize="13"
           Foreground="#2E7D5B"
           FontWeight="Bold"/>

                                    <!-- IMPORTANT INFO -->
                                    <TextBlock Text="Approx. 12 pcs • In Stock"
           FontSize="11"
           Foreground="Gray"
           Margin="0,4,0,8"/>
                                    <Separator Margin="0,6"/>

                                    <!-- SELLER INFO SECTION -->
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">

                                        <!-- PROFILE CIRCLE -->
                                        <Ellipse Width="32"
             Height="32"
             Fill="#CFEDE1"/>

                                        <StackPanel Margin="8,0,0,0">
                                            <TextBlock Text="Juan Dela Cruz"
                   FontSize="12"
                   FontWeight="SemiBold"/>
                                            <TextBlock Text="Davao City"
                   FontSize="11"
                   Foreground="Gray"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- ACTION BUTTON -->
                                    <Button Content="Add to Cart"
        Margin="0,10,0,0"
        Background="#2E7D5B"
        Foreground="White"
        BorderThickness="0"
        Padding="6"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </ScrollViewer>
                </ContentControl.Content>
            </ContentControl>

            <!-- LOGO – left, untouched -->
            <Border
            Background="White"
            CornerRadius="20"
            Padding="10,6"
            Margin="897,0,0,0"
            VerticalAlignment="Center"
            BorderBrush="#DCEAE3"
            BorderThickness="1"
            MaxWidth="350" HorizontalAlignment="Left" Width="186">

                <DockPanel>

                    <TextBlock Text="🔍"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    Foreground="#7C8A84"/>

                    <TextBox BorderThickness="0"
                    Background="Transparent"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="#1F4E3D"
                    Text="Search products..."/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>

</Window>
    