<Window x:Class="Marketplace_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Marketplace_System.Views"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        
        Title="FarmHub - Buyer Dashboard"
        Width="1200"
        Height="800"
        Background="#F3F8F4"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
        Background="#A8D5BA"
        Padding="20 15 0 15">
            <!-- Remove right padding to allow profile to be at edge -->
            <Grid VerticalAlignment="Center" Margin="-10,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="168"/>
                    <!-- Logo -->
                    <ColumnDefinition/>
                    <!-- Centered Navigation -->
                    <ColumnDefinition Width="Auto" MinWidth="210"/>
                    <!-- Profile at far right -->
                </Grid.ColumnDefinitions>

                <!-- LOGO -->
                <Button
                        Click="LogoButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Cursor="Hand"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" Height="77" Width="168">
                    <Image Source="pack://application:,,,/Images/logo2.png"
       Stretch="Uniform"
       MaxHeight="200" Height="77" Width="167"/>
                </Button>

                <!-- TOP NAVIGATION -->
                <Border Grid.Column="1"
                        Background="#E8F6ED"
                        CornerRadius="13"
                        Padding="12,8"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        BorderBrush="#CDE9DA"
                        BorderThickness="1" Width="332" Height="41" Margin="178,0,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="TopHomeNavButton"
                                Click="TopHomeNavButton_Click"
                                Content="Home"
                                Margin="0,0,8,0"
                                Padding="12,4"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#1F4E3D"
                                FontWeight="SemiBold"/>
                        <Button x:Name="TopOrdersNavButton"
                                Click="TopOrdersNavButton_Click"
                                Content="My Orders"
                                Margin="0,0,8,0"
                                Padding="12,4"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#1F4E3D"
                                FontWeight="SemiBold"/>
                        <Button x:Name="TopCartNavButton"
                                Click="TopCartNavButton_Click"
                                Content="Cart"
                                Margin="0,0,8,0"
                                Padding="12,4"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#1F4E3D"
                                FontWeight="SemiBold"/>
                        <Button x:Name="TopInboxNavButton"
                                Click="TopInboxNavButton_Click"
                                Content="Inbox"
                                Padding="12,4"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#1F4E3D"
                                FontWeight="SemiBold"/>

                    </StackPanel>
                </Border>
                <Border Background="White"
        CornerRadius="15"
        Padding="10,5"
        BorderBrush="#DCEAE3"
        BorderThickness="1" Margin="580,20,36,19" Grid.Column="1">

                    <DockPanel>

                        <!-- Search Icon -->
                        <TextBlock Text="🔍"
                   VerticalAlignment="Center"
                   Margin="5,0,8,0"
                   Foreground="#7C8A84"/>
                        <TextBox x:Name="SearchTextBox"
                 Text="Search products"
                 BorderThickness="0"
                 Background="Transparent"
                 Foreground="Gray"
                 VerticalContentAlignment="Center"
                 GotFocus="SearchTextBox_GotFocus"
                 LostFocus="SearchTextBox_LostFocus" DockPanel.Dock="Right" Width="151"/>

                        <!-- TextBox -->

                    </DockPanel>
                </Border>
                <!-- PROFILE DROPDOWN – at very right corner -->
                <Menu Grid.Column="2"
              Background="Transparent"
              VerticalAlignment="Center"
                           HorizontalAlignment="Center" Height="38" Width="220">
                    <MenuItem Background="Transparent" BorderThickness="0" Width="171" Click="MenuItem_Click">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="38" Height="38" CornerRadius="19" Background="White">
                                    <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" Foreground="#2E7D5B" RenderTransformOrigin="-0.119,0.449"/>
                                </Border>
                                <TextBlock x:Name="TopProfileNameTextBlock"
                                           Text="Guest"
                                           Margin="8,0,8,0"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="#1F4E3D"/>
                                <Path Data="M0,0 L6,6 L12,0" Fill="White" VerticalAlignment="Center"
                               Margin="0,0,0,0" Width="12" Height="6" Stretch="Uniform"/>
                            </StackPanel>
                        </MenuItem.Header>
                        <MenuItem.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="White"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#1F4E3D"/>
                        </MenuItem.Resources>
                        <MenuItem Header="My Profile" IsEnabled="False"/>
                        <MenuItem Header="Settings"/>
                        <Separator/>
                        <MenuItem Header="Logout" Click="LogoutMenuItem_Click"/>
                    </MenuItem>
                </Menu>
            </Grid>
        </Border>

        <!-- ========== MAIN CONTENT ========== -->
        <Grid Grid.Row="1" Margin="25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Make sure you have the FontAwesome namespace at the top of your XAML file -->
            <ContentControl x:Name="SidebarHost" Grid.Column="0"
                xmlns:fa="http://schemas.fontawesome.io/icons/">
                <ContentControl.Content>
                    <Border Background="White"
                CornerRadius="18"
                Padding="15"
                Margin="0,0,20,0">

                        <StackPanel>
                            <Button x:Name="BrowseProductsNavButton"
                                    Click="BrowseProductsNavButton_Click"
                                    Padding="10"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalContentAlignment="Stretch"
                                    Cursor="Hand"
                                    Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="ShoppingBasket"
                                                    Width="18"
                                                    Height="12"
                                                    Foreground="#5F6B6A"
                                                    VerticalAlignment="Center"/>
                                    <TextBlock Text="Browse Products"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ================= NAVIGATION SECTION ================= -->

                            <!-- MY ORDERS -->
                            <Button x:Name="MyOrdersNavButton"
        Click="MyOrdersNavButton_Click"
        Padding="10"
        Background="Transparent"
        BorderThickness="0"
        HorizontalContentAlignment="Stretch"
        Cursor="Hand"
        Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Clipboard"
                        Width="17"
                        Height="13"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                        <fa:FontAwesome.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform/>
                                                <SkewTransform/>
                                                <RotateTransform Angle="-0.082"/>
                                                <TranslateTransform/>
                                            </TransformGroup>
                                        </fa:FontAwesome.RenderTransform>
                                    </fa:FontAwesome>
                                    <TextBlock Text="My Orders"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- INBOX -->
                            <Button x:Name="InboxNavButton"
        Click="InboxNavButton_Click"
        Padding="10"
        Background="Transparent"
        BorderThickness="0"
        HorizontalContentAlignment="Stretch"
        Cursor="Hand"
        Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Inbox"
                        Width="18"
                        Height="10"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Inbox"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- CART -->
                            <Button x:Name="MyCartNavButton"
        Click="MyCartNavButton_Click"
        Padding="10"
        Background="Transparent"
        BorderThickness="0"
        HorizontalContentAlignment="Stretch"
        Cursor="Hand"
        Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="ShoppingCart"
                        Width="17"
                        Height="12"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="My Cart"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ================= SELLER TOOLS ================= -->

                            <Separator Margin="0,15"/>

                            <TextBlock Text="Seller Tools"
           FontWeight="Bold"
           Foreground="#1F4E3D"
           Margin="0,0,0,10"/>

                          
                            <!-- SELLING -->
                            <Button x:Name="SellingNavButton"
        Click="SellingNavButton_Click"
        Padding="10"
        Background="Transparent"
        BorderThickness="0"
        HorizontalContentAlignment="Stretch"
        Cursor="Hand"
        Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Tags"
                        Width="21"
                        Height="12"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Selling"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- ================= CATEGORIES ================= -->

                            <Separator Margin="0,20"/>

                            <TextBlock Text="Categories"
           FontSize="16"
           FontWeight="Bold"
           Margin="0,0,0,12"/>

                            <!-- Vegetables -->
                            <Border Padding="8" CornerRadius="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Leaf"
                        Width="15"
                        Height="10"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Vegetables"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Fruits -->
                            <Border Padding="8" CornerRadius="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Apple"
                        Width="16"
                        Height="12"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Fruits"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Leafy Greens -->
                            <Border Padding="8" CornerRadius="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Leaf"
                        Width="15"
                        Height="12"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Leafy Greens"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Root Crops -->
                            <Border Padding="8" CornerRadius="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Tree"
                        Width="17"
                        Height="13"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Root Crops"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Milk & Eggs -->
                            <Border Padding="8" CornerRadius="10" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Coffee"
                        Width="15"
                        Height="12"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Milk &amp; Eggs"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Organic Products -->
                            <Border Padding="8" CornerRadius="10">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Leaf"
                        Width="18"
                        Height="18"
                        Foreground="#5F6B6A"
                        VerticalAlignment="Center"/>
                                    <TextBlock Text="Organic Products"
                   Margin="12,0,0,0"
                   VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ContentControl.Content>
            </ContentControl>
            <ContentControl x:Name="MainContentHost" Grid.Column="1">
                <ContentControl.Content>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="-19,0,0,0">

                        <ItemsControl ItemsSource="{Binding BrowseProducts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Margin="0,0,0,20"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                <Border Width="290"
                                Margin="10"
                                Background="White"
                                CornerRadius="16"
                                Padding="8"
                                BorderBrush="#DCEAE3"
                                BorderThickness="1">

                                        <StackPanel>

                                            <Border Height="170"
                                        Background="#F3F8F4"
                                        CornerRadius="12"
                                        ClipToBounds="True">
                                                <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                            </Border>

                                            <TextBlock Text="{Binding ProductName}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Margin="0,12,0,2"/>

                                            <TextBlock Text="{Binding PriceText}"
                                           FontSize="13"
                                           Foreground="#2E7D5B"
                                           FontWeight="Bold"/>

                                            <TextBlock Text="{Binding StockText}"
                                           FontSize="11"
                                           Foreground="Gray"
                                           Margin="0,4,0,8"/>
                                            <Border Background="#E6F4EC" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMyProduct}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="Own product" FontSize="10" FontWeight="SemiBold" Foreground="#1F4E3D"/>
                                            </Border>
                                            <Separator Margin="0,6"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Ellipse Width="32" Height="30" Fill="#CFEDE1"/>
                                                <StackPanel Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding SellerName}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding SellerLocation}"
                                                   FontSize="11"
                                                   Foreground="Gray"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Button Content="{Binding ActionButtonText}"
                                        Margin="0,10,0,0"
                                        Background="#2E7D5B"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Padding="6"
                                         Click="AddToCartButton_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMyProduct}" Value="True">
                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                <Setter Property="Background" Value="#B0B0B0"/>
                                                                <Setter Property="Cursor" Value="Arrow"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </ScrollViewer>
                </ContentControl.Content>
            </ContentControl>
           

            <!-- LOGO – left, untouched -->
            <Border
            Background="White"
            CornerRadius="20"
            Padding="10,6"
            Margin="897,0,0,0"
            VerticalAlignment="Center"
            BorderBrush="#DCEAE3"
            BorderThickness="1"
            MaxWidth="350" HorizontalAlignment="Left" Width="186">

                <DockPanel>

                    <TextBlock Text="🔍"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    Foreground="#7C8A84"/>

                    <TextBox BorderThickness="0"
                    Background="Transparent"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="#1F4E3D"
                    Text="Search products..."/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>

</Window>
    