<Window x:Class="Marketplace_System.Views.SuperAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Marketplace_System.Views"
        Title="FarmHub Super Admin"
        Height="840"
        Width="1360"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="ModernNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Logout Button Style -->
        <Style x:Key="LogoutButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernNavButton}">
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D1A1A"/>
                    <Setter Property="Foreground" Value="#F87171"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#3B2020"/>
                    <Setter Property="Foreground" Value="#FCA5A5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Active Button Style -->
        <Style x:Key="ActiveNavButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernNavButton}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0F172A">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Row="0" Margin="20,24,20,20">
                    <TextBlock Text="🌾 FarmHub" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Super Admin Portal" Foreground="#94A3B8" Margin="0,4,0,0"/>
                    <Border Height="1" Background="#1E293B" Margin="0,16,0,0"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Row="1" Margin="16,0,16,0">
                    <Button x:Name="DashboardNavButton" 
                            Content="📊 Dashboard" 
                            Style="{StaticResource ModernNavButton}"
                            Margin="0,0,0,4"
                            Click="DashboardNavButton_Click"/>

                    <Button x:Name="ManageUsersNavButton" 
                            Content="👥 Manage Users" 
                            Style="{StaticResource ModernNavButton}"
                            Margin="0,0,0,4"
                            Click="ManageUsersNavButton_Click"/>

                    <Button x:Name="ManagePaymentsNavButton" 
                            Content="💰 Manage Payments" 
                            Style="{StaticResource ModernNavButton}"
                            Click="ManagePaymentsNavButton_Click"/>
                </StackPanel>

                <!-- Logout Button at Bottom -->
                <StackPanel Grid.Row="2" Margin="16,0,16,24">
                    <Border Height="1" Background="#1E293B" Margin="0,0,0,16"/>
                    <Button x:Name="LogoutButton" 
                            Content="🚪 Logout" 
                            Style="{StaticResource LogoutButtonStyle}"
                            Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,14">
                <TextBlock x:Name="ModuleTitleText" 
                          Text="Dashboard" 
                          FontSize="28" 
                          FontWeight="SemiBold"
                          Foreground="#0F172A"/>
                <TextBlock x:Name="ModuleSubtitleText" 
                          Text="Live system insights and controls" 
                          Foreground="#64748B"
                          FontSize="14"/>
            </StackPanel>

            <ContentControl Grid.Row="1" x:Name="ModuleHost"/>
        </Grid>
    </Grid>
</Window>