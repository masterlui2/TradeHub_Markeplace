<UserControl x:Class="Marketplace_System.Views.MyCartPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F8F4">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="My Cart" FontSize="28" FontWeight="SemiBold" Foreground="#1F4E3D"/>
            <TextBlock Text="Items saved from the marketplace." Margin="0,6,0,18" Foreground="#5F6B6A"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyCartTextBlock"
                       Text="Your cart is currently empty."
                       Foreground="#6B7280"
                       FontStyle="Italic"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CartItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="16" Padding="16" Margin="0,0,0,10" BorderBrush="#DCEAE3" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProductName}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding QuantityText}" Margin="0,4,0,0" Foreground="#5F6B6A"/>
                                        <TextBlock Text="{Binding SellerText}" Margin="0,2,0,0" Foreground="#7B8A86" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding TotalText}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#2E7D5B"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="16" BorderBrush="#DCEAE3" BorderThickness="1" Margin="0,12,0,0">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Total" Foreground="#5F6B6A"/>
                    <TextBlock x:Name="CartTotalTextBlock" Text="₱0.00" FontSize="24" FontWeight="Bold" Foreground="#1F4E3D"/>
                </StackPanel>
                <Button x:Name="CheckoutButton"
                        Content="Proceed to Checkout"
                        DockPanel.Dock="Right"
                        Background="#2E7D5B"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="18,10"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="CheckoutButton_Click"
                        IsEnabled="False"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>