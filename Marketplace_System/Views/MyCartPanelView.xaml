<UserControl x:Class="Marketplace_System.Views.MyCartPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F8F4">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="My Cart" FontSize="28" FontWeight="SemiBold" Foreground="#1F4E3D"/>
            <TextBlock Text="Select what to checkout, then choose pickup or delivery." Margin="0,6,0,18" Foreground="#5F6B6A"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyCartTextBlock"
                       Text="Your cart is currently empty."
                       Foreground="#6B7280"
                       FontStyle="Italic"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CartItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="16" Padding="16" Margin="0,0,0,10" BorderBrush="#DCEAE3" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"
                                              Checked="CartSelectionChanged"
                                              Unchecked="CartSelectionChanged"/>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding ProductName}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding QuantityText}" Margin="0,4,0,0" Foreground="#5F6B6A"/>
                                        <TextBlock Text="{Binding SellerText}" Margin="0,2,0,0" Foreground="#7B8A86" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding TotalText}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#2E7D5B"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="16" BorderBrush="#DCEAE3" BorderThickness="1" Margin="0,12,0,0">
            <StackPanel>
                <DockPanel LastChildFill="False" Margin="0,0,0,12">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Selected total" Foreground="#5F6B6A"/>
                        <TextBlock x:Name="CartTotalTextBlock" Text="₱0.00" FontSize="24" FontWeight="Bold" Foreground="#1F4E3D"/>
                    </StackPanel>
                </DockPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Fulfillment:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="FulfillmentMethodComboBox" Width="180" SelectionChanged="FulfillmentMethodComboBox_SelectionChanged">
                        <ComboBoxItem Content="Pick up" IsSelected="True"/>
                        <ComboBoxItem Content="Deliver"/>
                    </ComboBox>
                    <Button x:Name="CheckoutButton"
                            Content="Checkout Selected"
                            Background="#2E7D5B"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="18,10"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Margin="14,0,0,0"
                            Click="CheckoutButton_Click"
                            IsEnabled="False"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>