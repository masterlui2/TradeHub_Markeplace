<UserControl x:Class="Marketplace_System.Views.MyCartPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAF9">
    <UserControl.Resources>
        <!-- Shadow effect for cards -->
        <DropShadowEffect x:Key="CardShadow" 
                          BlurRadius="10" 
                          Opacity="0.1" 
                          ShadowDepth="2" 
                          Color="#808080"/>

        <!-- Style for TextBox with rounded corners -->
        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#D0E0D9"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="MaxHeight" Value="60"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="8" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="My Cart" 
                       FontSize="32" 
                       FontWeight="Light" 
                       Foreground="#1A3B2E">
                <TextBlock.TextEffects>
                    <TextEffect/>
                </TextBlock.TextEffects>
            </TextBlock>
            <TextBlock Text="Select items to checkout and set pickup or delivery per item" 
                       Margin="0,8,0,0" 
                       Foreground="#5E6F6B" 
                       FontSize="14"/>
            <Border Height="1" 
                    Background="#E5EDE9" 
                    Margin="0,16,0,0"/>
        </StackPanel>

        <!-- Cart Items Section -->
        <Grid Grid.Row="1">
            <!-- Empty State -->
            <Border x:Name="EmptyCartBorder"
                    Background="White"
                    CornerRadius="20"
                    Padding="48"
                    BorderBrush="#E5EDE9"
                    BorderThickness="1"
                    Visibility="Collapsed"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🛒" 
                               FontSize="48" 
                               TextAlignment="Center"
                               FontFamily="Segoe UI Emoji"/>
                    <TextBlock x:Name="EmptyCartTextBlock"
                               Text="Your cart is currently empty"
                               Foreground="#5E6F6B"
                               FontSize="16"
                               Margin="0,16,0,0"
                               TextAlignment="Center"/>
                    <TextBlock Text="Browse our marketplace and add items to get started"
                               Foreground="#8A9C97"
                               FontSize="14"
                               Margin="0,8,0,0"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Cart Items List -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          PanningMode="VerticalOnly">
                <ItemsControl x:Name="CartItemsControl"
                              Margin="0,0,8,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" 
                                    CornerRadius="20" 
                                    Padding="20" 
                                    Margin="0,0,0,12" 
                                    BorderBrush="#E5EDE9" 
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" 
                                                      Opacity="0.05" 
                                                      ShadowDepth="2" 
                                                      Color="#1A3B2E"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Checkbox -->
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,16,0"
                                              Style="{StaticResource ModernCheckBoxStyle}"/>

                                    <!-- Product Details -->
                                    <Grid Grid.Column="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Product Name and Quantity -->
                                        <StackPanel Grid.Row="0" 
                                                    Grid.ColumnSpan="2" 
                                                    Orientation="Horizontal">
                                            <TextBlock Text="{Binding ProductName}" 
                                                       FontSize="18" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="#1A3B2E"/>
                                            <TextBlock Text="{Binding QuantityText}" 
                                                       Margin="12,0,0,0"
                                                       FontSize="14"
                                                       Foreground="#5E6F6B"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Seller Info -->
                                        <TextBlock Grid.Row="1" 
                                                   Grid.ColumnSpan="2" 
                                                   Text="{Binding SellerText}" 
                                                   Margin="0,6,0,0" 
                                                   Foreground="#5E6F6B" 
                                                   FontSize="13"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.ColumnSpan="2"
                                                   Text="{Binding PickupAddressText}"
                                                   Margin="0,4,0,0"
                                                   Foreground="#2D6A4F"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>

                                        <!-- Fulfillment Selection -->
                                        <StackPanel Grid.Row="3" 
                                                    Grid.ColumnSpan="2" 
                                                    Orientation="Horizontal" 
                                                    Margin="0,12,0,0">
                                            <TextBlock Text="Fulfillment:" 
                                                       Foreground="#5E6F6B" 
                                                       VerticalAlignment="Center" 
                                                       Margin="0,0,12,0"
                                                       FontSize="13"/>
                                            <RadioButton Content="Pick up" 
                                                         GroupName="Fulfillment"
                                                         IsChecked="{Binding IsPickupSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Margin="0,0,16,0"
                                                         Style="{StaticResource ModernRadioButtonStyle}"/>
                                            <RadioButton Content="Deliver" 
                                                         GroupName="Fulfillment"
                                                         IsChecked="{Binding IsDeliverySelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource ModernRadioButtonStyle}"/>
                                        </StackPanel>

                                        <!-- Address Section -->
                                        <Border Grid.Row="4" 
                                                Grid.ColumnSpan="2"
                                                Background="#F3F8F4" 
                                                CornerRadius="12" 
                                                Padding="12" 
                                                Margin="0,12,0,0"
                                                Visibility="{Binding ShowAddressSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding AddressLabel}" 
                                                           Foreground="#1A3B2E" 
                                                           FontWeight="Medium" 
                                                           FontSize="12"
                                                           Margin="0,0,0,6"/>
                                                <TextBox Text="{Binding AddressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                         Style="{StaticResource RoundedTextBoxStyle}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Price -->
                                    <StackPanel Grid.Column="2" 
                                                VerticalAlignment="Center" 
                                                HorizontalAlignment="Right"
                                                Margin="20,0,0,0">
                                        <TextBlock Text="Total" 
                                                   Foreground="#8A9C97" 
                                                   FontSize="12"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding TotalText}" 
                                                   FontSize="20" 
                                                   FontWeight="SemiBold" 
                                                   Foreground="#2D6A4F"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Checkout Summary Section -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="20" 
                Padding="24" 
                BorderBrush="#E5EDE9" 
                BorderThickness="1"
                Margin="0,24,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Total and Terms -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,24,0">
                    <TextBlock Text="Selected Total" 
                               Foreground="#5E6F6B" 
                               FontSize="14"/>
                    <TextBlock x:Name="CartTotalTextBlock" 
                               Text="₱0.00" 
                               FontSize="32" 
                               FontWeight="Light" 
                               Foreground="#1A3B2E"/>
                    <Border Background="#F7FBF9"
                            BorderBrush="#DCEBE4"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Buyer Terms &amp; Conditions"
                                       FontWeight="SemiBold"
                                       Foreground="#1A3B2E"
                                       FontSize="13"/>
                            <TextBlock Text="Please review and accept before proceeding with your transaction."
                                       Margin="0,4,0,8"
                                       Foreground="#5E6F6B"
                                       FontSize="12"/>
                            <Expander Header="Review Terms"
                                      Foreground="#2D6A4F"
                                      FontWeight="SemiBold">
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#4B5F59"
                                           FontSize="12"
                                           Margin="0,8,0,0"
                                           Text="By checking out, you confirm that the selected quantity, fulfillment option, and address are accurate. You agree to complete payment on time, communicate respectfully with sellers, and comply with FarmHub marketplace policies for refunds, cancellations, and dispute handling."/>
                            </Expander>
                            <CheckBox x:Name="AcceptTncCheckBox"
                                      Margin="0,10,0,0"
                                      Content="I have reviewed and accept the Buyer Terms and Conditions."
                                      Foreground="#1A3B2E"
                                      Checked="AcceptTncCheckBox_Changed"
                                      Unchecked="AcceptTncCheckBox_Changed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Checkout Button -->
                <Button Grid.Column="1"
                        x:Name="CheckoutButton"
                        Content="Proceed to Checkout"
                        Background="#2D6A4F"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="32,14"
                        FontWeight="Medium"
                        FontSize="14"
                        Cursor="Hand"
                        IsEnabled="False"
                        Click="CheckoutButton_Click" Margin="0,122,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="30"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>