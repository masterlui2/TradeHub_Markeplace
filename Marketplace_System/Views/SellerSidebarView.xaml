<UserControl x:Class="Marketplace_System.Views.SellerSidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="Transparent">

    <Border Background="White"
            CornerRadius="18"
            Padding="15"
            Margin="0,0,20,0">
        <StackPanel>

            <TextBlock Text="Seller Tools"
                       FontWeight="Bold"
                       FontSize="16"
                       Foreground="#1F4E3D"
                       Margin="0,0,0,15"/>

            <Border Background="#E6F4EC"
                    CornerRadius="12"
                    Padding="10"
                    Margin="0,0,0,8">

                <StackPanel Orientation="Horizontal">
                    <fa:FontAwesome Icon="Dashboard"
                                    Width="18"
                                    Height="14"
                                    Foreground="#2E7D5B"
                                    VerticalAlignment="Center"/>

                    <TextBlock Text="Seller Dashboard"
                               Margin="12,0,0,0"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Button x:Name="CreateListingButton" Click="CreateListingButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="10"
                    Margin="0,0,0,8"
                    HorizontalContentAlignment="Stretch"
                    Cursor="Hand">

                <StackPanel Orientation="Horizontal">
                    <fa:FontAwesome Icon="PlusCircle"
                                    Width="19"
                                    Height="13"
                                    Foreground="#5F6B6A"
                                    VerticalAlignment="Center"/>

                    <TextBlock Text="Create Listing"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="ManageOrdersButton"
                    Click="ManageOrdersButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="10"
                    Margin="0,0,0,8"
                    HorizontalContentAlignment="Stretch"
                    Cursor="Hand">

                <StackPanel Orientation="Horizontal">
                    <fa:FontAwesome Icon="ShoppingBag"
                                    Width="20"
                                    Height="14"
                                    Foreground="#5F6B6A"
                                    VerticalAlignment="Center"/>

                    <TextBlock Text="Manage Orders"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="MessagesButton"
                    Click="MessagesButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="10"
                    Margin="0,0,0,8"
                    HorizontalContentAlignment="Stretch"
                    Cursor="Hand">

                <StackPanel Orientation="Horizontal">
                    <fa:FontAwesome Icon="Envelope"
                                    Width="18"
                                    Height="10"
                                    Foreground="#5F6B6A"
                                    VerticalAlignment="Center"/>

                    <TextBlock Text="Messages"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button x:Name="SalesInsightsButton"
                    Click="SalesInsightsButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="10"
                    Margin="0,0,0,8"
                    HorizontalContentAlignment="Stretch"
                    Cursor="Hand">

                <StackPanel Orientation="Horizontal">
                    <fa:FontAwesome Icon="LineChart"
                                    Width="20"
                                    Height="12"
                                    Foreground="#5F6B6A"
                                    VerticalAlignment="Center"/>

                    <TextBlock Text="Sales Insights"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
          
            <Button x:Name="ReturnToBuyerButton"
                    Click="ReturnToBuyerButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="10"
                    Margin="0,0,0,8"
                    HorizontalContentAlignment="Stretch"
                    Cursor="Hand">

                <StackPanel Orientation="Horizontal">
                    <fa:FontAwesome Icon="ArrowLeft"
                                    Width="17"
                                    Height="12"
                                    Foreground="#5F6B6A"
                                    VerticalAlignment="Center"/>

                    <TextBlock Text="Return to Buyer View"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
            <Separator Margin="0,20"/>

            <Button Background="Transparent"
                    BorderThickness="0"
                    Padding="10"
                    HorizontalContentAlignment="Stretch"
                    Cursor="Hand">

                <StackPanel Orientation="Horizontal">
                    <fa:FontAwesome Icon="User"
                                    Width="17"
                                    Height="12"
                                    Foreground="#5F6B6A"
                                    VerticalAlignment="Center"/>

                    <TextBlock Text="Marketplace Profile"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

        </StackPanel>
    </Border>
</UserControl>