<Window x:Class="Marketplace_System.Views.AdminPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FarmHub Admin Portal"
        Height="768"
        Width="1280"
        MinHeight="600"
        MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Colors -->
        <Color x:Key="PrimaryColor">#0F5132</Color>
        <Color x:Key="PrimaryLightColor">#E8F3E9</Color>
        <Color x:Key="SecondaryColor">#2D6A4F</Color>
        <Color x:Key="AccentColor">#40916C</Color>
        <Color x:Key="TextPrimaryColor">#1E293B</Color>
        <Color x:Key="TextSecondaryColor">#64748B</Color>
        <Color x:Key="BorderColor">#E2E8F0</Color>

        <!-- Shadow effect for cards -->
        <DropShadowEffect x:Key="ModuleCardShadow" 
                          BlurRadius="12" 
                          Opacity="0.05" 
                          ShadowDepth="2" 
                          Color="#000000"/>

        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Styles -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="6,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A2E3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2D3F4B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModuleCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource ModuleCardShadow}"/>
        </Style>
    </Window.Resources>

    <!-- Main Grid -->
    <Grid Background="#F5F7FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar - No Scrollbar -->
        <Border Grid.Column="0" 
                Background="#1A2A36">
            <Grid Margin="0,16,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo Section -->
                <StackPanel Grid.Row="0" Margin="20,0,20,24">
                    <TextBlock Text="🌾 FarmHub" 
                               FontSize="22" 
                               FontWeight="SemiBold" 
                               Foreground="White"
                               FontFamily="Segoe UI"/>
                    <TextBlock Text="Admin Portal" 
                               FontSize="13" 
                               Foreground="#94A3B8"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Navigation Menu - Fixed height to fit all items without scrolling -->
                <StackPanel Grid.Row="1" Margin="0,0,0,0">
                    <!-- Dashboard -->
                    <Button x:Name="DashboardButton" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="DashboardButton_Click"
                            Background="#2D3F4B"
                            Height="40">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Dashboard" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- User Management Group -->
                    <TextBlock Text="USER MANAGEMENT" 
                               Foreground="#64748B" 
                               FontSize="11" 
                               FontWeight="SemiBold"
                               Margin="20,16,0,6"/>

                    <Button x:Name="ManageUsersButton" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="ManageUsersButton_Click"
                            Height="38">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Manage Users" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="UserGridButton" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="UserGridButton_Click"
                            Height="38">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="User Grid View" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Product Management Group -->
                    <TextBlock Text="PRODUCTS &#38; SALES" 
                               Foreground="#64748B" 
                               FontSize="11" 
                               FontWeight="SemiBold"
                               Margin="20,16,0,6"/>

                    <Button x:Name="ManageListingsButton" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="ManageListingsButton_Click"
                            Height="38">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Product Listings" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ManagePaymentsButton" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="ManagePaymentsButton_Click"
                            Height="38">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Payment Records" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Communications Group -->
                    <TextBlock Text="COMMUNICATIONS" 
                               Foreground="#64748B" 
                               FontSize="11" 
                               FontWeight="SemiBold"
                               Margin="20,16,0,6"/>

                    <Button x:Name="SendMessagesButton" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="SendMessagesButton_Click"
                            Height="38">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📨" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Send Messages" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ActivityLogButton" 
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="ActivityLogButton_Click"
                            Height="38">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📜" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Activity Log" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer Section -->
                <StackPanel Grid.Row="2" Margin="20,0,20,0">
                    <Border Height="1" Background="#334454" Margin="0,0,0,12"/>

                    <Button x:Name="LogoutButton"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="LogoutButton_Click"
                            Height="38">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Logout" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="v1.0.0" 
                               Foreground="#475569" 
                               FontSize="10"
                               Margin="20,8,0,4"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Column="1" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#F5F7FA">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="16" 
                        Margin="0,0,0,16"
                        Effect="{StaticResource ModuleCardShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="PageTitleText" 
                                       Text="Dashboard" 
                                       FontSize="22" 
                                       FontWeight="SemiBold" 
                                       Foreground="#1E293B"/>
                            <TextBlock x:Name="PageSubtitleText" 
                                       Text="Welcome back, Admin" 
                                       Margin="0,2,0,0" 
                                       Foreground="#64748B" 
                                       FontSize="12"/>
                        </StackPanel>

                        <!-- Admin Profile -->
                        <Border Grid.Column="1" 
                                Background="#F1F5F9" 
                                CornerRadius="24" 
                                Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="#0F5132" 
                                        Width="26" 
                                        Height="26" 
                                        CornerRadius="13"
                                        Margin="0,0,6,0">
                                    <TextBlock Text="A" 
                                               Foreground="White" 
                                               FontSize="13" 
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="Administrator" 
                                               FontSize="11" 
                                               FontWeight="SemiBold" 
                                               Foreground="#1E293B"/>
                                    <TextBlock Text="Online" 
                                               FontSize="9" 
                                               Foreground="#2D6A4F"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Dynamic Content Area -->
                <Grid Grid.Row="1">

                    <!-- Dashboard Modules Grid -->
                    <Grid x:Name="DashboardGrid" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Stats Cards -->
                        <WrapPanel Grid.Row="0" Margin="0,0,0,20">
                            <Border Style="{StaticResource ModuleCardStyle}" Width="190" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="👥" FontSize="24" Margin="0,0,0,4"/>
                                    <TextBlock Text="Total Users" Foreground="#64748B" FontSize="11"/>
                                    <TextBlock Text="1,284" FontSize="20" FontWeight="Light" Foreground="#0F5132" Margin="0,4,0,0"/>
                                    <TextBlock Text="↑ 12% this month" Foreground="#2D6A4F" FontSize="9" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ModuleCardStyle}" Width="190" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="📦" FontSize="24" Margin="0,0,0,4"/>
                                    <TextBlock Text="Active Listings" Foreground="#64748B" FontSize="11"/>
                                    <TextBlock Text="456" FontSize="20" FontWeight="Light" Foreground="#0F5132" Margin="0,4,0,0"/>
                                    <TextBlock Text="32 pending review" Foreground="#EAB308" FontSize="9" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ModuleCardStyle}" Width="190" Margin="0,0,10,10">
                                <StackPanel>
                                    <TextBlock Text="💰" FontSize="24" Margin="0,0,0,4"/>
                                    <TextBlock Text="Revenue (MTD)" Foreground="#64748B" FontSize="11"/>
                                    <TextBlock Text="₱124.5K" FontSize="20" FontWeight="Light" Foreground="#0F5132" Margin="0,4,0,0"/>
                                    <TextBlock Text="↑ 8.3% vs last month" Foreground="#2D6A4F" FontSize="9" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!-- Section Title -->
                        <TextBlock Grid.Row="1" 
                                   Text="Quick Access Modules" 
                                   FontSize="15" 
                                   FontWeight="SemiBold" 
                                   Foreground="#1E293B"
                                   Margin="0,4,0,12"/>

                        <!-- Main Modules Grid -->
                        <UniformGrid Grid.Row="2" 
                                     Columns="3" 
                                     Rows="2"
                                     Margin="0,0,0,0">

                            <!-- Manage Users Module -->
                            <Border Style="{StaticResource ModuleCardStyle}" 
                                    Margin="0,0,10,10" 
                                    Cursor="Hand"
                                    MouseLeftButtonUp="ManageUsersButton_Click">
                                <StackPanel>
                                    <TextBlock Text="👥" FontSize="28" Margin="0,0,0,6"/>
                                    <TextBlock Text="Manage Users" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock Text="Suspend, verify, and update buyer/seller accounts" 
                                               Margin="0,4,0,0" 
                                               Foreground="#64748B" 
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Height="45"/>
                                    <Border Background="#F1F5F9" 
                                            CornerRadius="12" 
                                            Padding="6,3" 
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="24 new requests" Foreground="#0F5132" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Product Listings Module -->
                            <Border Style="{StaticResource ModuleCardStyle}" 
                                    Margin="0,0,10,10"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="ManageListingsButton_Click">
                                <StackPanel>
                                    <TextBlock Text="📦" FontSize="28" Margin="0,0,0,6"/>
                                    <TextBlock Text="Product Listings" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock Text="Review, edit, or deactivate posted products" 
                                               Margin="0,4,0,0" 
                                               Foreground="#64748B" 
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Height="45"/>
                                    <Border Background="#F1F5F9" 
                                            CornerRadius="12" 
                                            Padding="6,3" 
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="32 pending review" Foreground="#EAB308" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Sales Dashboard Module -->

                            <!-- Payment Records Module -->
                            <Border Style="{StaticResource ModuleCardStyle}" 
                                    Margin="0,0,10,0"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="ManagePaymentsButton_Click">
                                <StackPanel>
                                    <TextBlock Text="💰" FontSize="28" Margin="0,0,0,6"/>
                                    <TextBlock Text="Payment Records" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock Text="Review payment records and settlement statuses" 
                                               Margin="0,4,0,0" 
                                               Foreground="#64748B" 
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Height="45"/>
                                    <Border Background="#F1F5F9" 
                                            CornerRadius="12" 
                                            Padding="6,3" 
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="18 pending" Foreground="#EAB308" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Messages Module -->
                            <Border Style="{StaticResource ModuleCardStyle}" 
                                    Margin="0,0,10,0"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="SendMessagesButton_Click">
                                <StackPanel>
                                    <TextBlock Text="📨" FontSize="28" Margin="0,0,0,6"/>
                                    <TextBlock Text="Send Messages" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock Text="Send announcements and system notices to users" 
                                               Margin="0,4,0,0" 
                                               Foreground="#64748B" 
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Height="45"/>
                                    <Border Background="#F1F5F9" 
                                            CornerRadius="12" 
                                            Padding="6,3" 
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="Draft 3 messages" Foreground="#0F5132" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Activity Log Module -->
                            <Border Style="{StaticResource ModuleCardStyle}" 
                                    Margin="0,0,0,0"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="ActivityLogButton_Click">
                                <StackPanel>
                                    <TextBlock Text="📜" FontSize="28" Margin="0,0,0,6"/>
                                    <TextBlock Text="Activity Log" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock Text="Track administrative actions and sensitive events" 
                                               Margin="0,4,0,0" 
                                               Foreground="#64748B" 
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Height="45"/>
                                    <Border Background="#F1F5F9" 
                                            CornerRadius="12" 
                                            Padding="6,3" 
                                            Margin="0,10,0,0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="128 entries today" Foreground="#0F5132" FontSize="9"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>

                    <!-- Placeholder for other views -->
                    <Grid x:Name="ModuleContentGrid" Visibility="Collapsed">
                        <!-- Module-specific content will be loaded here -->
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>