<Window x:Class="Marketplace_System.Views.AdminPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Marketplace_System.Views"
        Title="FarmHub Admin Portal"
        Height="768"
        Width="1280"
        MinHeight="600"
        MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Loaded="Window_Loaded">

    <Window.Resources>
        <DropShadowEffect x:Key="ModuleCardShadow"
                          BlurRadius="12"
                          Opacity="0.05"
                          ShadowDepth="2"
                          Color="#000000"/>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="6,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A2E3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="RowActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ModuleCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{DynamicResource ModuleCardShadow}"/>        </Style>
        <Style x:Key="AdminComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="AdminDataGridStyle" TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F7FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1A2A36">
            <Grid Margin="0,16,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,0,20,24">
                    <TextBlock Text="🌾 FarmHub" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Admin Portal" FontSize="13" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="DashboardButton" Style="{DynamicResource SidebarButtonStyle}" Click="DashboardButton_Click" Background="#2D3F4B">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Dashboard" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="USER MANAGEMENT" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="20,16,0,6"/>
                    <Button x:Name="ManageUsersButton" Style="{DynamicResource SidebarButtonStyle}" Click="ManageUsersButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Manage Users" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="PLATFORM" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="20,16,0,6"/>
                    <Button x:Name="ManageListingsButton" Style="{DynamicResource SidebarButtonStyle}" Click="ManageListingsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Manage Listings" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ManagePaymentsButton" Style="{DynamicResource SidebarButtonStyle}" Click="ManagePaymentsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💳" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Payments" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ActivityLogButton" Style="{DynamicResource SidebarButtonStyle}" Click="ActivityLogButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧾" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Activity Log" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="20,0,20,0">
                    <Border Height="1" Background="#334454" Margin="0,0,0,12"/>
                    <Button x:Name="LogoutButton" Style="{DynamicResource SidebarButtonStyle}" Click="LogoutButton_Click" Height="38">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Logout" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,16" Effect="{DynamicResource ModuleCardShadow}">                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="PageTitleText" Text="Dashboard" FontSize="22" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock x:Name="PageSubtitleText" Text="Live platform summary" Margin="0,2,0,0" Foreground="#64748B" FontSize="12"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="Refresh data" Padding="12,6" FontSize="12" Click="RefreshButton_Click"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid x:Name="DashboardGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <UniformGrid Columns="4" Margin="0,0,0,16">
                            <Border Style="{DynamicResource ModuleCardStyle}" Margin="0,0,10,0">                                <StackPanel>
                                    <TextBlock Text="Users" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding TotalUsers}" FontSize="26" FontWeight="SemiBold" Foreground="#0F5132"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{DynamicResource ModuleCardStyle}" Margin="0,0,10,0">                                <StackPanel>
                                    <TextBlock Text="Listings" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding TotalListings}" FontSize="26" FontWeight="SemiBold" Foreground="#0F5132"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{DynamicResource ModuleCardStyle}" Margin="0,0,10,0">                                <StackPanel>
                                    <TextBlock Text="Active Orders" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding ActiveOrders}" FontSize="26" FontWeight="SemiBold" Foreground="#0F5132"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{DynamicResource ModuleCardStyle}">                                <StackPanel>
                                    <TextBlock Text="Revenue (This Month)" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding RevenueThisMonth, StringFormat=C}" FontSize="26" FontWeight="SemiBold" Foreground="#0F5132"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="1" Style="{DynamicResource ModuleCardStyle}" Margin="0,0,0,12">                            <StackPanel>
                                <TextBlock Text="Snapshot" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                                <TextBlock Text="{Binding DashboardSummary}" Margin="0,6,0,0" Foreground="#475569" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="2" Style="{DynamicResource ModuleCardStyle}">                            <StackPanel>
                                <TextBlock Text="Recent Activity" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                                <TextBlock Text="{Binding ActivityLogSummary}" Margin="0,4,0,10" Foreground="#64748B" TextWrapping="Wrap"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="220">
                                    <ItemsControl ItemsSource="{Binding ActivityLogs}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="130"/>
                                                            <ColumnDefinition Width="95"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding TimeLabel}" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                                        <Border Grid.Column="1" Background="#E2F0FF" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Category}" Foreground="#1D4ED8" FontWeight="SemiBold" FontSize="11"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding Action}" Foreground="#0F172A" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding Details}" Foreground="#475569" FontSize="12" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="ModuleContentGrid" Visibility="Collapsed">
                        <Border Style="{DynamicResource ModuleCardStyle}">                            <Grid>
                                <!-- USERS MODULE -->
                                <Grid x:Name="UsersModuleGrid">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="Users" FontSize="16" FontWeight="SemiBold"
                               Foreground="#1E293B" DockPanel.Dock="Left"/>
                                        <TextBox Width="260" Height="34" Padding="10,4"
                             Text="{Binding UserSearchText, UpdateSourceTrigger=PropertyChanged}"
                             DockPanel.Dock="Right"/>
                                    </DockPanel>

                                    <TextBlock Grid.Row="1"
                           Text="{Binding UserTableSummary}"
                           Margin="0,0,0,8"
                           Foreground="#64748B"/>

                                    <DataGrid Grid.Row="2"
                          Style="{DynamicResource AdminDataGridStyle}"                          ItemsSource="{Binding UsersView}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="2*"/>
                                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                                            <DataGridTextColumn Header="City" Binding="{Binding City}" Width="*"/>
                                            <DataGridTextColumn Header="Joined" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="*"/>
                                            <DataGridTextColumn Header="Last Activity" Binding="{Binding LastActivityLabel}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>

                                <!-- LISTINGS MODULE -->
                                <Grid x:Name="ListingsModuleGrid" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="Listings" FontSize="18" FontWeight="SemiBold"
                               Foreground="#0F172A" DockPanel.Dock="Left"/>
                                        <TextBox Width="260" Height="34" Padding="10,4"
                             Text="{Binding ListingSearchText, UpdateSourceTrigger=PropertyChanged}"
                             DockPanel.Dock="Right"/>
                                    </DockPanel>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                        <ComboBox Style="{DynamicResource AdminComboBoxStyle}" Width="150"                              SelectedValuePath="Content" SelectedValue="{Binding ListingStatusFilter}">
                                            <ComboBoxItem Content="All statuses"/>
                                            <ComboBoxItem Content="Active"/>
                                            <ComboBoxItem Content="Low Stock"/>
                                            <ComboBoxItem Content="Sold Out"/>
                                        </ComboBox>
                                        <ComboBox Style="{DynamicResource AdminComboBoxStyle}" Width="140"                              SelectedValuePath="Content" SelectedValue="{Binding ListingSortBy}">
                                            <ComboBoxItem Content="Newest"/>
                                            <ComboBoxItem Content="Oldest"/>
                                            <ComboBoxItem Content="Highest Price"/>
                                            <ComboBoxItem Content="Lowest Stock"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <TextBlock Grid.Row="2" Text="{Binding ListingTableSummary}"
                           Margin="0,0,0,8" Foreground="#64748B"/>

                                    <DataGrid Grid.Row="3"
                          Style="{DynamicResource AdminDataGridStyle}"
                                              ItemsSource="{Binding ListingsView}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="2*"/>
                                            <DataGridTextColumn Header="Seller" Binding="{Binding SellerName}" Width="*"/>
                                            <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                                            <DataGridTextColumn Header="Price/kg" Binding="{Binding PricePerKilo, StringFormat=C}" Width="*"/>
                                            <DataGridTextColumn Header="Stock" Binding="{Binding AvailableKilos}" Width="80"/>
                                            <DataGridTextColumn Header="Sold" Binding="{Binding SoldKilos}" Width="80"/>
                                            <DataGridTemplateColumn Header="Status" Width="120">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{Binding StatusBackground}" CornerRadius="12"
                                            Padding="10,4" HorizontalAlignment="Left">
                                                            <TextBlock Text="{Binding Status}"
                                                   Foreground="{Binding StatusForeground}"
                                                   FontWeight="SemiBold" FontSize="12"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat=C}" Width="*"/>
                                            <DataGridTextColumn Header="Joined" Binding="{Binding CreatedAt, StringFormat=\{0:yyyy-MM-dd\}}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                                <!-- PAYMENTS MODULE -->
                                <Grid x:Name="PaymentsModuleGrid" Visibility="Collapsed">
                                    <views:AdminManagePaymentsView/>
                                </Grid>

                                <!-- ACTIVITY LOG MODULE -->
                                <Grid x:Name="ActivityLogModuleGrid" Visibility="Collapsed">
                                    <views:AdminActivityLogsView/>
                                </Grid>

                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>