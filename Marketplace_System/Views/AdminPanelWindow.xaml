<Window x:Class="Marketplace_System.Views.AdminPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FarmHub Admin Portal"
        Height="768"
        Width="1280"
        MinHeight="600"
        MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        Loaded="Window_Loaded">

    <Window.Resources>
        <DropShadowEffect x:Key="ModuleCardShadow"
                          BlurRadius="12"
                          Opacity="0.05"
                          ShadowDepth="2"
                          Color="#000000"/>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="6,2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1A2E3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModuleCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect" Value="{StaticResource ModuleCardShadow}"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F5F7FA">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1A2A36">
            <Grid Margin="0,16,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,0,20,24">
                    <TextBlock Text="🌾 FarmHub" FontSize="22" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Admin Portal" FontSize="13" Foreground="#94A3B8" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="DashboardButton" Style="{StaticResource SidebarButtonStyle}" Click="DashboardButton_Click" Background="#2D3F4B">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Dashboard" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="USER MANAGEMENT" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="20,16,0,6"/>
                    <Button x:Name="ManageUsersButton" Style="{StaticResource SidebarButtonStyle}" Click="ManageUsersButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Manage Users" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="UserGridButton" Style="{StaticResource SidebarButtonStyle}" Click="UserGridButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="User Grid" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="PLATFORM" Foreground="#64748B" FontSize="11" FontWeight="SemiBold" Margin="20,16,0,6"/>
                    <Button x:Name="ManageListingsButton" Style="{StaticResource SidebarButtonStyle}" Click="ManageListingsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Manage Listings" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ManagePaymentsButton" Style="{StaticResource SidebarButtonStyle}" Click="ManagePaymentsButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💳" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Payments" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SendMessagesButton" Style="{StaticResource SidebarButtonStyle}" Click="SendMessagesButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📨" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Messages" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ActivityLogButton" Style="{StaticResource SidebarButtonStyle}" Click="ActivityLogButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧾" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Activity Log" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="20,0,20,0">
                    <Border Height="1" Background="#334454" Margin="0,0,0,12"/>
                    <Button x:Name="LogoutButton" Style="{StaticResource SidebarButtonStyle}" Click="LogoutButton_Click" Height="38">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Logout" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,16" Effect="{StaticResource ModuleCardShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="PageTitleText" Text="Dashboard" FontSize="22" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBlock x:Name="PageSubtitleText" Text="Live platform summary" Margin="0,2,0,0" Foreground="#64748B" FontSize="12"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="Refresh data" Padding="12,6" FontSize="12" Click="RefreshButton_Click"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid x:Name="DashboardGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <UniformGrid Columns="4" Margin="0,0,0,16">
                            <Border Style="{StaticResource ModuleCardStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Users" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding TotalUsers}" FontSize="26" FontWeight="SemiBold" Foreground="#0F5132"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ModuleCardStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Listings" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding TotalListings}" FontSize="26" FontWeight="SemiBold" Foreground="#0F5132"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ModuleCardStyle}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Active Orders" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding ActiveOrders}" FontSize="26" FontWeight="SemiBold" Foreground="#0F5132"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ModuleCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Revenue (This Month)" Foreground="#64748B" FontSize="12"/>
                                    <TextBlock Text="{Binding RevenueThisMonth, StringFormat=C}" FontSize="26" FontWeight="SemiBold" Foreground="#0F5132"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="1" Style="{StaticResource ModuleCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Snapshot" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B"/>
                                <TextBlock Text="{Binding DashboardSummary}" Margin="0,6,0,0" Foreground="#475569" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="ModuleContentGrid" Visibility="Collapsed">
                        <Border Style="{StaticResource ModuleCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Text="Users" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" DockPanel.Dock="Left"/>
                                    <TextBox Width="260" Height="30" Padding="8,4" Text="{Binding UserSearchText, UpdateSourceTrigger=PropertyChanged}" DockPanel.Dock="Right"/>
                                </DockPanel>

                                <TextBlock Grid.Row="1" Text="{Binding UserTableSummary}" Margin="0,0,0,8" Foreground="#64748B"/>

                                <DataGrid Grid.Row="2"
                                          ItemsSource="{Binding UsersView}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowHeaderWidth="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                        <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="2*"/>
                                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                                        <DataGridTextColumn Header="City" Binding="{Binding City}" Width="*"/>
                                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="*"/>
                                        <DataGridTextColumn Header="Joined" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="*"/>
                                        <DataGridTextColumn Header="Last Activity" Binding="{Binding LastActivityLabel}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>