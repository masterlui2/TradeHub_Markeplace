<UserControl x:Class="Marketplace_System.Views.SuperAdminManageUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,10">
            <Button Content="+ Add User" Width="120" Height="34" Click="AddUser_Click"/>
        </DockPanel>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Users}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                <DataGridTextColumn Header="Mobile" Binding="{Binding MobileNumber}" Width="*"/>
                <DataGridTextColumn Header="City" Binding="{Binding City}" Width="*"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                <DataGridTemplateColumn Header="Suspend" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Tag="{Binding}"
                                    Content="{Binding SuspendActionLabel}"
                                    Padding="10,4"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    BorderThickness="1"
                                    Click="SuspendToggle_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#FEF2F2"/>
                                        <Setter Property="Foreground" Value="#B91C1C"/>
                                        <Setter Property="BorderBrush" Value="#FECACA"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSuspended}" Value="True">
                                                <Setter Property="Background" Value="#ECFDF5"/>
                                                <Setter Property="Foreground" Value="#047857"/>
                                                <Setter Property="BorderBrush" Value="#A7F3D0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Actions" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="👁" Tag="{Binding}" Click="ViewUser_Click" Margin="0,0,6,0"/>
                                <Button Content="✏️" Tag="{Binding}" Click="EditUser_Click" Margin="0,0,6,0"/>
                                <Button Content="🗑" Tag="{Binding}" Click="DeleteUser_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>