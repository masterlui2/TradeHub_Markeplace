<UserControl x:Class="Marketplace_System.Views.SellerSalesInsightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border Background="White"
            CornerRadius="18"
            Padding="20"
            BorderBrush="#DCEAE3"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Sales Insights"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1F4E3D"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Live summary based on your current orders and completed sales."
                       Foreground="#6B7280"
                       Margin="0,0,0,14"/>

            <UniformGrid Columns="3" Margin="0,0,0,18">
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="TotalRevenueTextBlock" Text="₱0.00" FontSize="22" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Completed Revenue" Foreground="#374151"/>
                    </StackPanel>
                </Border>
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="TotalOrdersTextBlock" Text="0" FontSize="22" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Total Orders" Foreground="#374151"/>
                    </StackPanel>
                </Border>
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14">
                    <StackPanel>
                        <TextBlock x:Name="CompletionRateTextBlock" Text="0%" FontSize="22" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Completion Rate" Foreground="#374151"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Top Performing Product" FontSize="12" Foreground="Gray"/>
                    <TextBlock x:Name="TopProductNameTextBlock" Text="No completed orders yet" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    <TextBlock x:Name="TopProductDetailsTextBlock" Text="Once orders are completed, your best seller appears here." Foreground="#374151"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14">
                <StackPanel>
                    <TextBlock Text="Best Sales Day" FontSize="12" Foreground="Gray"/>
                    <TextBlock x:Name="BestDayTextBlock" Text="No sales day yet" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    <TextBlock x:Name="BestDayDetailsTextBlock" Text="We'll highlight your strongest day by revenue." Foreground="#374151"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>