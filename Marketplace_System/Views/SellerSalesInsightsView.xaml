<UserControl x:Class="Marketplace_System.Views.SellerSalesInsightsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border Background="White"
            CornerRadius="18"
            Padding="20"
            BorderBrush="#DCEAE3"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Sales Insights"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1F4E3D"
                       Margin="0,0,0,14"/>

            <UniformGrid Columns="3" Margin="0,0,0,18">
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="₱18,450" FontSize="22" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="This Week" Foreground="#374151"/>
                    </StackPanel>
                </Border>
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="+14%" FontSize="22" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Growth" Foreground="#374151"/>
                    </StackPanel>
                </Border>
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14">
                    <StackPanel>
                        <TextBlock Text="46" FontSize="22" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Orders" Foreground="#374151"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Top Performing Product" FontSize="12" Foreground="Gray"/>
                    <TextBlock Text="Organic Lettuce" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    <TextBlock Text="17 units sold this week" Foreground="#374151"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="14">
                <StackPanel>
                    <TextBlock Text="Best Sales Day" FontSize="12" Foreground="Gray"/>
                    <TextBlock Text="Friday" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    <TextBlock Text="₱4,820 revenue across 11 orders" Foreground="#374151"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>