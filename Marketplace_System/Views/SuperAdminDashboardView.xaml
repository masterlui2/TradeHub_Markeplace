<UserControl x:Class="Marketplace_System.Views.SuperAdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <UniformGrid Columns="4" Margin="0,0,0,16">
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Total Users" Foreground="#64748B"/>
                        <TextBlock Text="{Binding TotalUsers}" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Total Sales" Foreground="#64748B"/>
                        <TextBlock Text="{Binding TotalSales}" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Revenue" Foreground="#64748B"/>
                        <TextBlock Text="{Binding Revenue, StringFormat=C}" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Active Listings" Foreground="#64748B"/>
                        <TextBlock Text="{Binding ActiveListings}" FontSize="22" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Sales Trend (Last 7 days)" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding SalesTrends}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Bottom" Margin="4,0">
                                        <Border Background="#2563EB" Height="{Binding Height}" MinHeight="4" MaxHeight="120" CornerRadius="3" VerticalAlignment="Bottom"/>
                                        <TextBlock Text="{Binding Label}" FontSize="10" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="System Alerts" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding Alerts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="•  {Binding}" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="Recent Transactions" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <DataGrid ItemsSource="{Binding RecentTransactions}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ref" Binding="{Binding ReferenceNumber}" Width="*"/>
                            <DataGridTextColumn Header="Order" Binding="{Binding OrderNumber}" Width="*"/>
                            <DataGridTextColumn Header="Payer" Binding="{Binding PayerName}" Width="*"/>
                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C}" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
