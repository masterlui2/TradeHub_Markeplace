<UserControl x:Class="Marketplace_System.Views.SellerMessagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border Background="White"
            CornerRadius="18"
            Padding="20"
            BorderBrush="#DCEAE3"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Messages"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1F4E3D"
                       Margin="0,0,0,14"/>

            <TextBox Text="Search conversations..."
                     Foreground="Gray"
                     Background="#F9FAFB"
                     BorderBrush="#E5E7EB"
                     BorderThickness="1"
                     Padding="10"
                     Margin="0,0,0,16"/>

            <Border Background="#F3F8F4" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="Maria L."
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="2m ago"
                                   DockPanel.Dock="Right"
                                   Foreground="Gray"
                                   FontSize="12"/>
                    </DockPanel>
                    <TextBlock Text="Can you deliver the spinach by 4 PM?"
                               Foreground="#374151"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="Daniel C."
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="21m ago"
                                   DockPanel.Dock="Right"
                                   Foreground="Gray"
                                   FontSize="12"/>
                    </DockPanel>
                    <TextBlock Text="Thanks! I'll confirm the order tonight."
                               Foreground="#374151"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="12">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="Ari N."
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="1h ago"
                                   DockPanel.Dock="Right"
                                   Foreground="Gray"
                                   FontSize="12"/>
                    </DockPanel>
                    <TextBlock Text="Do you have 10kg of tomatoes available?"
                               Foreground="#374151"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>