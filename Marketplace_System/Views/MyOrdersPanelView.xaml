<UserControl x:Class="Marketplace_System.Views.MyOrdersPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F8F4">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="My Orders" FontSize="28" FontWeight="SemiBold" Foreground="#1F4E3D"/>
            <TextBlock Text="Track your active and recent purchases." Margin="0,6,0,18" Foreground="#5F6B6A"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyOrdersTextBlock"
                       Text="No orders yet. Checkout from your cart to create one."
                       Foreground="#6B7280"
                       FontStyle="Italic"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="OrdersItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="16" Padding="18" Margin="0,0,0,12" BorderBrush="#DCEAE3" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding OrderNumber}" FontWeight="SemiBold" FontSize="16"/>
                                        <TextBlock Text="{Binding ProductSummary}" Margin="0,4,0,0" Foreground="#5F6B6A"/>
                                        <TextBlock Text="{Binding SellerName}" Margin="0,3,0,0" Foreground="#5F6B6A"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Status}" Background="#FFF1C6" Foreground="#856404" Padding="10,4" FontWeight="SemiBold" TextAlignment="Center"/>
                                        <TextBlock Text="{Binding TotalText}" Margin="0,10,0,0" Foreground="#2E7D5B" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>