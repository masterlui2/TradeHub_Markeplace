<UserControl x:Class="Marketplace_System.Views.MyOrdersPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F8F4">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="My Orders" FontSize="28" FontWeight="SemiBold" Foreground="#1F4E3D"/>
            <TextBlock Text="Track your active and recent purchases." Margin="0,6,0,18" Foreground="#5F6B6A"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyOrdersTextBlock"
                       Text="No orders yet. Checkout from your cart to create one."
                       Foreground="#6B7280"
                       FontStyle="Italic"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="OrdersItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="16" Padding="18" Margin="0,0,0,12" BorderBrush="#DCEAE3" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding OrderNumber}" FontWeight="SemiBold" FontSize="16"/>
                                        <TextBlock Text="{Binding ProductSummary}" Margin="0,4,0,0" Foreground="#5F6B6A"/>
                                        <TextBlock Text="{Binding SellerName}" Margin="0,3,0,0" Foreground="#5F6B6A"/>
                                        <TextBlock Text="{Binding FulfillmentText}" Margin="0,3,0,0" Foreground="#2E7D5B"/>
                                        <TextBlock Text="{Binding LastUpdatedText}" Margin="0,3,0,0" Foreground="#6B7280" FontSize="12"/>
                                        <TextBlock Text="{Binding AddressText}" Margin="0,3,0,0" Foreground="#5F6B6A" FontSize="12" TextWrapping="Wrap" MaxWidth="640"/>
                                        <Border Margin="0,12,0,0" Padding="12" CornerRadius="10" Background="#F8FBF9" BorderBrush="#DCEAE3" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="Receipt" FontWeight="SemiBold" Foreground="#1F4E3D"/>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Quantity" Foreground="#5F6B6A"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding QuantityText}" Foreground="#1F2937"/>
                                                </Grid>
                                                <Grid Margin="0,2,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Unit price" Foreground="#5F6B6A"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding UnitPriceText}" Foreground="#1F2937"/>
                                                </Grid>
                                                <Separator Margin="0,8,0,8" Background="#DCEAE3"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Total" FontWeight="SemiBold" Foreground="#1F4E3D"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding TotalText}" FontWeight="SemiBold" Foreground="#2E7D5B"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <Border Background="{Binding StatusBackground}" BorderBrush="{Binding StatusBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="12,6" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Status}" Foreground="{Binding StatusForeground}" FontWeight="SemiBold" TextAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding TotalText}" Margin="0,10,0,0" Foreground="#2E7D5B" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>