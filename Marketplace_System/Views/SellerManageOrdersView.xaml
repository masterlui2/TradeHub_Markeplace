<UserControl x:Class="Marketplace_System.Views.SellerManageOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border Background="White"
            CornerRadius="18"
            Padding="20"
            BorderBrush="#DCEAE3"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Manage Orders"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1F4E3D"
                       Margin="0,0,0,14"/>

            <UniformGrid Columns="3" Margin="0,0,0,18">
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="12" FontSize="24" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Pending" Foreground="#374151"/>
                    </StackPanel>
                </Border>
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="4" FontSize="24" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Ready for Pickup" Foreground="#374151"/>
                    </StackPanel>
                </Border>
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14">
                    <StackPanel>
                        <TextBlock Text="28" FontSize="24" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Completed" Foreground="#374151"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="#FH-1542 • 8kg Carrots" FontWeight="SemiBold"/>
                        <TextBlock Text="Buyer: Grace M.  •  Delivery today" Foreground="Gray" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Text="Pending" DockPanel.Dock="Right" Foreground="#B45309" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="12">
                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="#FH-1539 • 5 sacks Potatoes" FontWeight="SemiBold"/>
                        <TextBlock Text="Buyer: Kian R.  •  Pickup tomorrow" Foreground="Gray" FontSize="12"/>
                    </StackPanel>
                    <TextBlock Text="Ready" DockPanel.Dock="Right" Foreground="#15803D" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>