<UserControl x:Class="Marketplace_System.Views.SellerManageOrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border Background="White"
            CornerRadius="18"
            Padding="20"
            BorderBrush="#DCEAE3"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Manage Orders"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1F4E3D"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Confirm payment first, then progress orders to completion."
                       Foreground="#5F6B6A"
                       Margin="0,0,0,14"/>

            <UniformGrid Columns="4" Margin="0,0,0,18">
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="PendingCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Pending payment" Foreground="#374151"/>
                    </StackPanel>
                </Border>
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="PreparingCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Preparing" Foreground="#374151"/>
                    </StackPanel>
                </Border>
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock x:Name="ReadyCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Ready" Foreground="#374151"/>
                    </StackPanel>
                </Border>
                <Border Background="#F3F8F4" CornerRadius="12" Padding="14">
                    <StackPanel>
                        <TextBlock x:Name="CompletedCountText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#2E7D5B"/>
                        <TextBlock Text="Completed" Foreground="#374151"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock x:Name="EmptyOrdersTextBlock"
                       Text="No customer orders yet."
                       Foreground="#6B7280"
                       FontStyle="Italic"
                       Margin="0,0,0,10"
                       Visibility="Collapsed"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="520">
                <ItemsControl x:Name="OrdersItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="{Binding OrderLine}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding BuyerLine}" Foreground="Gray" FontSize="12" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding FulfillmentLine}" Foreground="#2E7D5B" FontSize="12" Margin="0,3,0,0"/>
                                        <TextBlock Text="{Binding AddressLine}" Foreground="#5F6B6A" FontSize="12" Margin="0,3,0,0" TextWrapping="Wrap" MaxWidth="650"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Status}" Foreground="#1F4E3D" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        <Button Content="{Binding ActionText}"
                                                Tag="{Binding OrderId}"
                                                Click="AdvanceStatusButton_Click"
                                                Padding="10,4"
                                                Margin="0,8,0,0"
                                                Background="#2E7D5B"
                                                Foreground="White"
                                                BorderThickness="0"
                                                Visibility="{Binding ActionVisibility}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>